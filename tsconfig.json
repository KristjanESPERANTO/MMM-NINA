{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitAny": true,
    "strict": true,
    "noUnusedLocals": true,
    "noImplicitThis": true,
    "sourceMap": false,
    "target": "ES2024",
    "lib": ["DOM", "ESNext"],
    "types": ["magicmirror-module"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*.ts"]
}
